FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/FormAutoHub.Api/FormAutoHub.Api.csproj src/FormAutoHub.Api/
RUN dotnet restore src/FormAutoHub.Api/FormAutoHub.Api.csproj

COPY . .
RUN dotnet publish src/FormAutoHub.Api/FormAutoHub.Api.csproj \
    --configuration Release \
    --no-restore \
    --output /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
ENV ASPNETCORE_ENVIRONMENT=Production
ENV ASPNETCORE_URLS=http://+:8080
COPY --from=build /app/publish .
EXPOSE 8080
ENTRYPOINT ["dotnet", "FormAutoHub.Api.dll"]
